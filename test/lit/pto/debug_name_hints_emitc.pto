// RUN: ptoas %s | FileCheck %s

module {
  func.func @name_hints_basic(%lhs: i32, %rhs: i32) {
    %0 = func.call @name_hints_basic_helper(%lhs, %rhs) : (i32, i32) -> i32
    return
  }

  func.func private @name_hints_basic_helper(%lhs: i32, %rhs: i32) -> i32 {
    %sum0 = arith.addi %lhs, %rhs : i32 loc("sum.value")
    %sum1 = arith.addi %sum0, %sum0 : i32 loc("sum value")
    %sum2 = arith.addi %sum1, %sum0 : i32 loc("class")
    %sum3 = arith.addi %sum2, %sum1 : i32
    %sum4 = arith.addi %sum2, %sum3 : i32
    return %sum4 : i32
  }
}

